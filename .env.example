# Copy this file to `.env` and fill in the values for your environment.
# Never commit the real .env to version control.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HTTP listen port. Default 3100.
PORT=3100

# Absolute path to the SQLite database file. Use an absolute path in production
# because systemd services run from WorkingDirectory and a relative path will
# land in an unexpected place. The directory will be created if missing.
DATABASE_PATH=/opt/price-tracker/data/price-tracker.db

# Set to `production` to enable fail-fast checks on JWT_SECRET and
# SETTINGS_ENCRYPTION_KEY, and to skip noisy dev-only logging.
NODE_ENV=production

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# Signs JWT access and refresh tokens. REQUIRED in production — the server
# refuses to start without it when NODE_ENV=production.
# Generate with: openssl rand -hex 64
JWT_SECRET=

# -----------------------------------------------------------------------------
# Settings encryption
# -----------------------------------------------------------------------------

# AES-256-GCM key used to encrypt webhook URLs and tokens at rest in the
# settings table. Accepts either a base64-encoded 32-byte key (preferred,
# high entropy) or any passphrase (SHA-256'd to 32 bytes).
#
# REQUIRED in production — the server refuses to start without it.
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# WARNING: if you rotate this key, existing encrypted settings become
# unreadable. Key rotation is a planned feature (the storage format has a
# v1: version prefix for this) but not yet implemented — plan accordingly.
SETTINGS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Scraper
# -----------------------------------------------------------------------------

# Number of retry attempts on transient scrape failures (network errors,
# timeouts, 5xx responses). Total attempts = SCRAPE_MAX_RETRIES + 1.
# Deterministic failures like 4xx fail fast regardless.
SCRAPE_MAX_RETRIES=2

# Base delay in milliseconds for exponential backoff between retries.
# Actual delay = SCRAPE_RETRY_BASE_MS * 3^attempt.
# Default 1000 → retries at 1s, 3s.
SCRAPE_RETRY_BASE_MS=1000

# AI Buyer's Assistant (Claude API)
AI_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
